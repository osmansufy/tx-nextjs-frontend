# WordPress headless backend
# Base URL of your WP install (no trailing slash, no /wp-json suffix)
NEXT_PUBLIC_WP_API_URL=https://your-wp-site.com

# Public URL of this Next.js app (used for canonical/OG metadata)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: override the LMS REST namespace if your plugin exposes a different one
# NEXT_PUBLIC_LMS_NAMESPACE=lms/v1
