# =====================================================================
# tx-headless-frontend — environment variables
# Copy to .env.local and fill in values. Never commit .env.local.
# =====================================================================

# === REQUIRED ===
# Base URL of your WordPress install (no trailing slash, no /wp-json suffix)
NEXT_PUBLIC_WP_API_URL=https://your-wp-site.com

# Public URL of this Next.js app (used for canonical / OG metadata)
NEXT_PUBLIC_SITE_URL=https://your-frontend.com

# === API ===
# LMS REST namespace — must match the plugin (default: lms-backend/v1)
NEXT_PUBLIC_LMS_NAMESPACE=lms-backend/v1

# Optional server-only WP URL — use when the public domain shouldn't be
# exposed and a private network route exists (e.g. http://wp-backend:8080)
# WP_API_URL=https://your-wp-site.com

# CDN prefix for media/uploads (leave blank to use WP origin)
NEXT_PUBLIC_CDN_URL=

# === OPTIONAL SITE IDENTITY OVERRIDES ===
# These fall back to GET /lms-backend/v1/settings from the WordPress API.
# Set them only if the backend settings endpoint is unavailable.
NEXT_PUBLIC_SITE_NAME=
NEXT_PUBLIC_LOGO_URL=
NEXT_PUBLIC_LOGO_DARK_URL=
NEXT_PUBLIC_PRIMARY_COLOR=
NEXT_PUBLIC_ACCENT_COLOR=
NEXT_PUBLIC_CURRENCY=GBP
NEXT_PUBLIC_LOCALE=en-GB

# === FEATURE FLAGS ===
# These fall back to GET /settings `features` object.
# Set to "false" to force-disable regardless of the settings endpoint.
NEXT_PUBLIC_FEATURE_MEMBERSHIPS=true
NEXT_PUBLIC_FEATURE_BUNDLES=true
NEXT_PUBLIC_FEATURE_CERTIFICATES=true
NEXT_PUBLIC_FEATURE_BADGES=false
NEXT_PUBLIC_FEATURE_REVIEWS=true
NEXT_PUBLIC_FEATURE_BLOG=true

# === PAYMENTS ===
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# === MONITORING ===
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# === ON-DEMAND REVALIDATION ===
# Shared secret verified by /api/revalidate (called from WP save_post hook)
WP_REVALIDATE_SECRET=

# === NEWSLETTER ===
# API key for Mailchimp / Brevo / SendGrid behind /api/newsletter
NEWSLETTER_PROVIDER_API_KEY=
